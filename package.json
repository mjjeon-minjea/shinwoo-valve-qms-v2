{
  "name": "shinwoo-valve-qms",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "homepage": "https://mjjeon-minjea.github.io/shinwoo-valve-qms",
  "scripts": {
    "dev": "vite --host",
    "server:json": "node server.js",
    "server:gateway": "node server/index.js",
    "db": "concurrently \"npm run server:json\" \"npm run server:gateway\"",
    "start": "concurrently \"npm run db\" \"npm run dev\"",
    "build": "vite build",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "predeploy": "cross-env VITE_GH_PAGES=true npm run build",
    "deploy": "gh-pages -d dist",
    "db:sync": "powershell -ExecutionPolicy Bypass -File scripts/sync-db.ps1",
    "db:pull": "node scripts/sync-db.js pull",
    "db:push": "node scripts/sync-db.js push"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.91.0",
    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "html2canvas": "^1.4.1",
    "is-port-reachable": "^4.0.0",
    "jspdf": "^4.0.0",
    "localtunnel": "^2.0.2",
    "lucide-react": "^0.300.0",
    "multer": "^2.0.2",
    "node-cron": "^4.2.1",
    "node-fetch": "^3.3.2",
    "node-notifier": "^10.0.1",
    "nodemailer": "^8.0.3",
    "pg": "^8.20.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^7.12.0",
    "recharts": "^3.6.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "csv-parser": "^3.2.0",
    "eslint": "^8.55.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "gh-pages": "^6.3.0",
    "json-server": "^0.17.4",
    "playwright": "^1.58.2",
    "postcss": "^8.4.32",
    "supabase": "^2.84.10",
    "tailwindcss": "^3.4.0",
    "vite": "^5.0.8"
  }
}
