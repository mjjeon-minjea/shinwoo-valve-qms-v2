558\uace0 \uac00\uce58 \uc788\ub294 \ub2e8\uc77c \uc561\uc158 \uc544\uc774\ud15c 1\uac1c\ub97c \uacb0\uc815\ud558\uace0, \uc774 \uc791\uc5c5\uc744 \uc218\ud589\ud560 \uc5d0\uc774\uc804\ud2b8 1~2\uba85\uc744 \uc9c0\uc815\ud558\uc5ec '\ub370\uc77c\ub9ac \uc561\uc158 \uc544\uc774\ud15c' \ubcf4\uace0\uc11c \ud615\ud0dc\ub85c \uc791\uc131\ud574 \uc8fc\uc138\uc694. \uc774\uc804\uc5d0 \uc791\uc131\ub41c '\uc6cc\ud06c\ud50c\ub85c\uc6b0 \ub9f5 \uc644\uc131'\uacfc\ub294 \ub2e4\ub978 \uac01\ub3c4(\uc608: \ubb38\uc11c\ud654, \ub2e4\uc74c \uae30\ub2a5 \uc815\uc758, \uc0ac\uc6a9\uc790 \ud53c\ub4dc\ubc31 \uc900\ube44 \ub4f1)\ub85c \uc811\uadfc\ud574\uc57c \ud569\ub2c8\ub2e4.", "file_type": "document", "source_file": "C:\\Users\\mjjeon\\Desktop\\QMS \ud504\ub85c\uc81d\ud2b8\\shinwoo-valve-qms\\\ud074\ub85c\ub4dc\\company\\_company\\sessions\\2026-05-11T04-08\\secretary.md", "source_location": "L1"}, {"id": "2026_05_11t04_08_secretary_\ub370\uc77c\ub9ac_\uc561\uc158_\uc544\uc774\ud15c_\ubcf4\uace0\uc11c_2026_05_11", "label": "\ud83d\udcc5 \ub370\uc77c\ub9ac \uc561\uc158 \uc544\uc774\ud15c \ubcf4\uace0\uc11c (2026-05-11)", "file_type": "document", "source_file": "C:\\Users\\mjjeon\\Desktop\\QMS \ud504\ub85c\uc81d\ud2b8\\shinwoo-valve-qms\\\ud074\ub85c\ub4dc\\company\\_company\\sessions\\2026-05-11T04-08\\secretary.md", "source_location": "L13"}], "edges": [{"source": "c_users_mjjeon_desktop_qms_\ud504\ub85c\uc81d\ud2b8_shinwoo_valve_qms_\ud074\ub85c\ub4dc_company_company_sessions_2026_05_11t04_08_secretary_md", "target": "2026_05_11t04_08_secretary_\uc601\uc219_ceo\uc758_\uac1c\uc778_\uba54\ubaa8\ub9ac_\ud68c\uc0ac_\uacf5\ub3d9_\ubaa9\ud45c_\uadf8\ub9ac\uace0_\ucd5c\uadfc_24\uc2dc\uac04_\ub3d9\uc548\uc758_\uc758\uc0ac\uacb0\uc815_\ub85c\uadf8_e2e_\ud14c\uc2a4\ud2b8_\ubc0f_\uc6cc\ud06c\ud50c\ub85c\uc6b0_\ub9f5_\uc791\uc131_\uc9c0\uc2dc_\ub97c_\uc885\ud569\uc801\uc73c\ub85c_\uac80\ud1a0\ud558\uc5ec_\ub2e4\uc74c_\uc0ac\uc774\ud074\uc5d0\uc11c_\uac00\uc7a5_\uc2dc\uae09\ud558\uace0_\uac00