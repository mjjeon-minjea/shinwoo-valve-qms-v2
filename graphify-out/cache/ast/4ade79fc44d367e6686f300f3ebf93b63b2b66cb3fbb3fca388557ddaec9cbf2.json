5\uc744 \uc218\ud589\ud560 \uc5d0\uc774\uc804\ud2b8 1~2\uba85\uc744 \uc9c0\uc815\ud558\ub294 '\ub370\uc77c\ub9ac \uc561\uc158 \uc544\uc774\ud15c' \ubcf4\uace0\uc11c \ud615\ud0dc\ub85c \uc791\uc131\ud574 \uc8fc\uc138\uc694. (\ubc18\ubcf5\ub418\ub294 \ub0b4\uc6a9\uc774 \uc544\ub2c8\ub3c4\ub85d \ubc18\ub4dc\uc2dc \uc0c8\ub85c\uc6b4 \uad00\uc810\uacfc \ucd08\uc810\uc744 \uc7a1\uc544\uc57c \ud569\ub2c8\ub2e4.)", "file_type": "document", "source_file": "C:\\Users\\mjjeon\\Desktop\\QMS \ud504\ub85c\uc81d\ud2b8\\shinwoo-valve-qms\\\ud074\ub85c\ub4dc\\company\\_company\\sessions\\2026-05-11T04-38\\secretary.md", "source_location": "L1"}, {"id": "2026_05_11t04_38_secretary_\ub370\uc77c\ub9ac_\uc561\uc158_\uc544\uc774\ud15c_\ubcf4\uace0\uc11c", "label": "\u2728 \ud83d\udcc5 \ub370\uc77c\ub9ac \uc561\uc158 \uc544\uc774\ud15c \ubcf4\uace0\uc11c", "file_type": "document", "source_file": "C:\\Users\\mjjeon\\Desktop\\QMS \ud504\ub85c\uc81d\ud2b8\\shinwoo-valve-qms\\\ud074\ub85c\ub4dc\\company\\_company\\sessions\\2026-05-11T04-38\\secretary.md", "source_location": "L13"}], "edges": [{"source": "c_users_mjjeon_desktop_qms_\ud504\ub85c\uc81d\ud2b8_shinwoo_valve_qms_\ud074\ub85c\ub4dc_company_company_sessions_2026_05_11t04_38_secretary_md", "target": "2026_05_11t04_38_secretary_\uc601\uc219_ceo\uc758_\uac1c\uc778_\uba54\ubaa8\ub9ac_\ud68c\uc0ac_\uacf5\ub3d9_\ubaa9\ud45c_\uadf8\ub9ac\uace0_\ucd5c\uadfc_24\uc2dc\uac04\uc758_\ubaa8\ub4e0_\uc758\uc0ac\uacb0\uc815_\ub85c\uadf8_\uc6cc\ud06c\ud50c\ub85c\uc6b0_\ub9f5_\uc644\uc131_\uc2a4\ud1a0\ub9ac\ub9f5_\uc131\uacf5\uc870\uac74_\uc815\uc758_\ub97c_\uc885\ud569\uc801\uc73c\ub85c_\ubd84\uc11d\ud558\uc5ec_\ud604\uc7ac_\uc2dc\uc810\uc5d0\uc11c_\uac00\uc7a5_\ub192\uc740_\uc6b0\uc120\uc21c\uc704\uc758_\ub2e8\uc77c_\uc791\uc5c5_\uc744_1\uac1c_\uacb0\uc815\ud558\uace0_\uc774_\uc791\uc5c5\uc744_\uc218\ud589\ud560_\uc5d0\uc774\uc804\ud2b8_1_2\uba85\uc744_\uc9c0\uc815\ud558\ub294_\ub370\uc77c\ub9ac_\uc561\uc158_\uc544\uc774\ud15c_\ubcf4\uace0\uc11c_\ud