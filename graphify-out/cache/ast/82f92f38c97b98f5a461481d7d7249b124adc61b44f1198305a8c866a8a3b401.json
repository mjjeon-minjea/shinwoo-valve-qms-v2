218\ud589\ud560 \uc5d0\uc774\uc804\ud2b8 1~2\uba85\uc744 \uc9c0\uc815\ud558\ub294 '\ub370\uc77c\ub9ac \uc561\uc158 \uc544\uc774\ud15c' \ubcf4\uace0\uc11c \ud615\ud0dc\ub85c \uc791\uc131\ud574 \uc8fc\uc138\uc694. (\uc774\uc804\uc5d0 \ubcf4\uace0\ub41c \ubaa8\ub4e0 \ub0b4\uc6a9\uacfc \uc911\ubcf5\ub418\uc9c0 \uc54a\ub3c4\ub85d, \ud68c\uc0ac \uc6b4\uc601\uc758 \ub2e4\uc74c \ub2e8\uacc4(\uc608: \ub0b4\ubd80 \ud504\ub85c\uc138\uc2a4 \uc815\uc758, \uc608\uc0b0 \uacc4\ud68d, \uc678\ubd80 \ud30c\ud2b8\ub108\uc2ed \ud0d0\uc0c9 \ub4f1)\uc5d0 \ucd08\uc810\uc744 \ub9de\ucdb0\uc57c \ud569\ub2c8\ub2e4.)", "file_type": "document", "source_file": "C:\\Users\\mjjeon\\Desktop\\QMS \ud504\ub85c\uc81d\ud2b8\\shinwoo-valve-qms\\\ud074\ub85c\ub4dc\\company\\_company\\sessions\\2026-05-11T06-38\\secretary.md", "source_location": "L1"}, {"id": "2026_05_11t06_38_secretary_\ub370\uc77c\ub9ac_\uc561\uc158_\uc544\uc774\ud15c_\ubcf4\uace0\uc11c_\uc6b4\uc601_\ud504\ub85c\uc138\uc2a4_\uc815\uc758", "label": "\ud83d\udcc5 [\ub370\uc77c\ub9ac \uc561\uc158 \uc544\uc774\ud15c \ubcf4\uace0\uc11c] - \uc6b4\uc601 \ud504\ub85c\uc138\uc2a4 \uc815\uc758", "file_type": "document", "source_file": "C:\\Users\\mjjeon\\Desktop\\QMS \ud504\ub85c\uc81d\ud2b8\\shinwoo-valve-qms\\\ud074\ub85c\ub4dc\\company\\_company\\sessions\\2026-05-11T06-38\\secretary.md", "source_location": "L13"}], "edges": [{"source": "c_users_mjjeon_desktop_qms_\ud504\ub85c\uc81d\ud2b8_shinwoo_valve_qms_\ud074\ub85c\ub4dc_company_company_sessions_2026_05_11t06_38_secretary_md", "target": "2026_05_11t06_38_secretary_\uc601\uc219_ceo\uc758_\uac1c\uc778_\uba54\ubaa8\ub9ac_\ud68c\uc0ac_\uacf5\ub3d9_\ubaa9\ud45c_\uadf8\ub9ac\uace0_\ucd5c\uadfc_24\uc2dc\uac04_\ub3d9\uc548\uc758_\ubaa8\ub4e0_\uc758\uc0ac\uacb0\uc815_\ub85c\uadf8\ub97c_\uc885\ud569\uc801\uc73c\ub85c_\ubd84\uc11d\ud558\uc5ec_\ud604\uc7ac_\uc2dc\uc810\uc5d0\uc11c_\uac00\uc7a5_\ub192\uc740_\uc6b0\uc120\uc21c\uc704\uc758_\ub2e8\uc77c_\uc791\uc5c5_1\uac1c\ub97c_\uacb0\uc815\ud558\uace0_